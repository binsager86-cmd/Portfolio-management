# ──────────────────────────────────────────────────────────────────────
# Portfolio Mobile API — Environment Variables
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before running.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────────────
# "development" = permissive CORS, verbose logs
# "production"  = strict CORS, no debug info in errors
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────────
# Path to SQLite file, relative to backend-api/ or absolute.
DATABASE_PATH=../dev_portfolio.db

# ── Security ─────────────────────────────────────────────────────────
# JWT signing key — MUST be a long random string in production.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_BEFORE_PRODUCTION

# JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call this API.
# In development mode (ENVIRONMENT=development), all origins are allowed.
CORS_ORIGINS=https://your-app.vercel.app,https://your-app.netlify.app

# ── Cron / Price Scheduler ───────────────────────────────────────────
# Secret key for POST /api/cron/update-prices (header X-Cron-Key or ?key=).
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
CRON_SECRET_KEY=CHANGE_ME_BEFORE_PRODUCTION

# Daily auto-update schedule (24-hour, Asia/Kuwait timezone)
PRICE_UPDATE_ENABLED=true
PRICE_UPDATE_HOUR=17
PRICE_UPDATE_MINUTE=0

# ── FX ───────────────────────────────────────────────────────────────
# Cache TTL for USD/KWD exchange rate (seconds)
FX_CACHE_TTL=3600

# ── AI / Gemini (optional) ───────────────────────────────────────────
# Google Gemini API key for the /api/ai/analyze endpoint.
# Leave blank to disable AI features.
GEMINI_API_KEY=

# ── SMTP / Email (for password reset) ───────────────────────────────
# Gmail: use smtp.gmail.com + App Password (not your regular password)
#   1. Enable 2FA on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail"
# SendGrid: use smtp.sendgrid.net, port 587, user "apikey", password = API key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Portfolio Tracker
SMTP_USE_TLS=true

# Password reset OTP settings
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
